# Frontend Configuration
VITE_API_URL=http://localhost:3000/api

# For Vercel deployment, use:
# VITE_API_URL=https://your-vercel-domain.vercel.app/api

# Backend Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ikbr_db

# For Vercel Postgres, use Vercel dashboard to set this automatically
# Or use any PostgreSQL provider (Supabase, RDS, etc.)

# JWT Secret for authentication (generate a strong secret)
JWT_SECRET=your-super-secret-key-change-this-in-production

# Admin authentication password (change this immediately in production!)
ADMIN_PASSWORD=jaeseanjae

# Environment
NODE_ENV=production

# App Configuration
VITE_APP_NAME=Interactive Brokers
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=false

# Optional: Third-party services
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
